{
  "apps" : [{
    "name": "chat",
    "script": "app.js",
    "instances": "1",
    "exec_mode": "fork",
    "watch": true,
    "ignore_watch": [
      "node_modules",
      "public",
      "\./(processes|package).*\.json"
    ],
    "env": {
      "NODE_ENV": "development"
    },
    "env_production": {
      "NODE_ENV": "production"
    }
  }]
}